:root {
  --brand-blue: #176a9f;
  --brand-blue-dark: #0c3556;
  --brand-blue-soft: #eaf7ff;
  --brand-gold: #c99a43;
  --brand-text: #213847;
  --muted-text: #667783;
  --line: #dbe9f1;
  --paper: #ffffff;
  --warm-bg: #fbf8f1;
  --soft-bg: #f4f9fc;
  --shadow-soft: 0 18px 48px rgba(12, 53, 86, 0.1);
  --shadow-card: 0 14px 34px rgba(12, 53, 86, 0.08);
}

html {
  scroll-behavior: smooth;
}

body {
  color: var(--brand-text);
  background:
    linear-gradient(180deg, #f8fcff 0%, #fffaf2 42%, #f5fbff 100%);
  font-family: "Noto Sans TC", "Microsoft JhengHei", Arial, sans-serif;
}

a {
  color: var(--brand-blue);
}

a:hover,
a:focus {
  color: var(--brand-blue-dark);
}

.btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 44px;
  padding: 10px 18px;
  border-radius: 999px;
  font-weight: 900;
  letter-spacing: 0;
}

.btn-primary,
.header-get-a-quote .btn-primary {
  background: var(--brand-blue);
  border-color: var(--brand-blue);
  box-shadow: 0 12px 26px rgba(23, 106, 159, 0.2);
}

.btn-primary:hover,
.btn-primary:focus,
.header-get-a-quote .btn-primary:hover {
  color: #fff !important;
  background: var(--brand-blue-dark);
  border-color: var(--brand-blue-dark);
}

.btn-dark {
  color: var(--brand-blue-dark);
  background: #fff;
  border: 1px solid var(--line);
  box-shadow: none;
}

.btn-dark:hover,
.btn-dark:focus {
  color: #fff !important;
  background: var(--brand-blue-dark);
  border-color: var(--brand-blue-dark);
}

.top-bar {
  background: rgba(255, 255, 255, 0.82);
  border-bottom: 1px solid var(--line);
}

.top-bar-content {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18px;
  min-height: 44px;
  padding: 7px 0;
}

.top-bar-main {
  display: flex;
  flex-wrap: wrap;
  gap: 10px 22px;
  color: #314b5d;
  font-size: 14px;
  font-weight: 800;
}

.top-bar-main span {
  display: inline-flex;
  align-items: center;
  gap: 8px;
}

.top-bar-main i {
  color: var(--brand-blue);
}

.top-bar-cta {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 34px;
  padding: 8px 18px;
  color: #fff;
  background: var(--brand-blue);
  border-radius: 999px;
  font-size: 14px;
  font-weight: 900;
  white-space: nowrap;
  box-shadow: 0 10px 22px rgba(23, 106, 159, 0.18);
}

.top-bar-cta:hover,
.top-bar-cta:focus {
  color: #fff;
  background: var(--brand-blue-dark);
}

.logo-area {
  padding: 18px 0;
}

.brand-logo {
  align-items: center;
  gap: 12px;
}

.brand-logo img {
  width: 58px;
  height: 58px;
  object-fit: contain;
  border-radius: 50%;
}

.brand-logo strong,
.brand-logo small {
  display: block;
}

.brand-logo strong {
  color: var(--brand-blue-dark);
  font-size: 24px;
  line-height: 1.1;
}

.brand-logo small {
  color: #6c7d88;
  font-size: 13px;
  font-weight: 700;
}

.header-one .site-navigation,
.navbar-fixed {
  background: var(--brand-blue-dark);
}

.nav-link {
  font-size: 15px;
  font-weight: 800;
}

.hero-area {
  position: relative;
  overflow: hidden;
  padding: 76px 0 56px;
  background:
    radial-gradient(circle at 88% 20%, rgba(23, 106, 159, 0.12), transparent 34%),
    linear-gradient(120deg, rgba(234, 247, 255, 0.96), rgba(255, 250, 242, 0.9));
}

.hero-area::after {
  position: absolute;
  right: -120px;
  bottom: -170px;
  width: 360px;
  height: 360px;
  content: "";
  background: rgba(23, 106, 159, 0.08);
  border-radius: 50%;
  pointer-events: none;
}

.hero-layout {
  position: relative;
  z-index: 1;
}

.hero-copy {
  max-width: 660px;
}

.hero-kicker {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  margin-bottom: 16px;
  padding: 7px 13px;
  color: var(--brand-blue) !important;
  background: rgba(255, 255, 255, 0.78);
  border: 1px solid var(--line);
  border-radius: 999px;
  font-size: 14px !important;
  font-weight: 900;
  letter-spacing: 0;
}

.hero-copy h1 {
  color: var(--brand-blue-dark);
  font-size: clamp(34px, 3.3vw, 48px);
  font-weight: 900;
  line-height: 1.36;
  margin-bottom: 20px;
}

.hero-copy p {
  max-width: 620px;
  color: #536879;
  font-size: 17px;
  line-height: 1.95;
}

.hero-actions {
  display: flex;
  flex-wrap: wrap;
  gap: 12px;
  margin-top: 28px;
}

.hero-actions .btn {
  min-width: 160px;
  padding: 13px 22px;
  font-size: 15px;
}

.trust-tags {
  display: grid;
  grid-template-columns: repeat(4, minmax(0, 1fr));
  gap: 12px;
  margin-top: 28px;
}

.trust-tags span {
  display: flex;
  align-items: center;
  gap: 9px;
  min-width: 0;
  color: var(--brand-blue-dark);
  font-size: 14px;
  font-weight: 900;
  line-height: 1.35;
}

.trust-tags i {
  display: inline-grid;
  flex: 0 0 30px;
  width: 30px;
  height: 30px;
  color: var(--brand-blue);
  background: #fff;
  border: 1px solid var(--line);
  border-radius: 50%;
  place-items: center;
  box-shadow: 0 8px 18px rgba(12, 53, 86, 0.07);
}

.conversion-visual {
  max-width: 520px;
  margin-left: auto;
  padding: 24px;
  background:
    linear-gradient(180deg, rgba(255, 255, 255, 0.96), rgba(246, 251, 254, 0.96));
  border: 1px solid var(--line);
  border-radius: 28px;
  box-shadow: var(--shadow-soft);
}

.hero-card-label {
  margin-bottom: 14px;
  color: var(--brand-blue-dark);
  font-size: 15px;
  font-weight: 900;
}

.hero-image-wrap {
  position: relative;
  padding: 16px;
  background: #fff;
  border: 1px solid #e4eef5;
  border-radius: 22px;
}

.hero-brand-image {
  display: block;
  width: 100%;
  max-width: 420px;
  margin: 0 auto;
  object-fit: contain;
  border-radius: 14px;
}

.hero-before-after-slot {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 10px;
}

.hero-before-after-slot figure {
  display: grid;
  aspect-ratio: 4 / 3;
  margin: 0;
  color: var(--muted-text);
  background: var(--brand-blue-soft);
  border: 1px dashed #bfd7e6;
  border-radius: 14px;
  font-size: 14px;
  font-weight: 900;
  place-items: center;
}

.hero-mini-tags {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 8px;
  margin-top: 14px;
}

.hero-mini-tags span {
  padding: 9px 8px;
  color: var(--brand-blue-dark);
  background: var(--brand-blue-soft);
  border: 1px solid #d8e9f3;
  border-radius: 999px;
  font-size: 13px;
  font-weight: 900;
  text-align: center;
}

.call-to-action-box {
  margin-top: -24px;
  position: relative;
  z-index: 2;
}

.call-to-action-box .action-style-box {
  padding: 28px 32px;
  background: rgba(255, 255, 255, 0.96);
  border: 1px solid var(--line);
  border-radius: 22px;
  box-shadow: var(--shadow-soft);
}

.call-to-action-text .action-title {
  margin-bottom: 6px;
  color: var(--brand-blue-dark);
  font-size: clamp(24px, 2.4vw, 30px);
  line-height: 1.25;
}

.action-text {
  max-width: 760px;
  margin-bottom: 0;
  color: var(--muted-text);
  font-size: 16px;
  line-height: 1.8;
}

.cta-line-btn {
  padding: 13px 22px;
  color: #fff !important;
  background: var(--brand-blue);
  border-color: var(--brand-blue);
  font-size: 15px;
  box-shadow: 0 12px 28px rgba(23, 106, 159, 0.2);
}

.cta-line-btn:hover,
.cta-line-btn:focus {
  color: #fff !important;
  background: var(--brand-blue-dark);
  border-color: var(--brand-blue-dark);
}

.section-padding {
  padding: 78px 0;
}

.section-title {
  margin-bottom: 8px;
  color: var(--brand-blue);
  font-size: 15px;
  font-weight: 900;
}

.section-sub-title {
  color: var(--brand-blue-dark);
  font-size: clamp(27px, 3vw, 38px);
  line-height: 1.32;
  margin-bottom: 38px;
}

.services {
  background: rgba(255, 255, 255, 0.5);
}

.service-card-row {
  margin-top: 4px;
}

.service-card,
.scene-card,
.quote-card,
.case-card,
.faq-box,
.contact-info-box,
.contact-form {
  height: 100%;
  background: var(--paper);
  border: 1px solid var(--line);
  border-radius: 22px;
  box-shadow: var(--shadow-card);
}

.service-card {
  display: flex;
  flex-direction: column;
  padding: 30px;
}

.service-icon {
  display: inline-grid;
  width: 48px;
  height: 48px;
  margin-bottom: 20px;
  color: #fff;
  background: var(--brand-blue);
  border-radius: 16px;
  place-items: center;
  box-shadow: 0 12px 26px rgba(23, 106, 159, 0.2);
}

.service-card h3,
.scene-card h3,
.case-card h3,
.quote-card h3,
.contact-info-box h3,
.faq-box h4 {
  color: var(--brand-blue-dark);
  font-weight: 900;
}

.service-card h3 {
  margin-bottom: 12px;
  font-size: 24px;
}

.service-card p,
.scene-card p,
.case-card dd,
.quote-card p,
.faq-box p,
.contact-info-box p {
  color: var(--muted-text);
  line-height: 1.8;
}

.service-card ul {
  display: grid;
  gap: 10px;
  margin: 16px 0 24px;
  padding: 0;
  list-style: none;
}

.service-card li {
  display: flex;
  gap: 8px;
  color: var(--brand-blue-dark);
  font-weight: 800;
}

.service-card li::before {
  color: var(--brand-blue);
  content: "✓";
  font-weight: 900;
}

.service-link {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  align-self: flex-start;
  min-height: 44px;
  margin-top: auto;
  padding: 10px 18px;
  color: var(--brand-blue-dark);
  background: var(--brand-blue-soft);
  border: 1px solid #d8e9f3;
  border-radius: 999px;
  font-weight: 900;
}

.service-link:hover,
.service-link:focus {
  color: #fff;
  background: var(--brand-blue);
}

.scene-area {
  background: linear-gradient(180deg, #f4f9fc, #fffaf2);
}

.scene-list {
  margin-top: 2px;
}

.scene-card {
  padding: 24px;
}

.scene-card h3 {
  margin-bottom: 10px;
  font-size: 20px;
}

.scene-card p {
  margin-bottom: 0;
  font-size: 15px;
}

.quote-method {
  background: rgba(255, 255, 255, 0.7);
}

.quote-card {
  padding: 30px;
}

.quote-card span {
  display: inline-block;
  margin-bottom: 18px;
  color: var(--brand-gold);
  font-weight: 900;
}

.cases-area {
  background: #f8fcff;
}

.case-compact {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24px;
  max-width: 940px;
  margin: 0 auto;
  padding: 30px;
  background: #fff;
  border: 1px solid var(--line);
  border-radius: 22px;
  box-shadow: var(--shadow-card);
}

.case-compact .section-title {
  margin-bottom: 8px;
}

.case-compact h3 {
  margin-bottom: 10px;
  color: var(--brand-blue-dark);
  font-size: clamp(24px, 2.7vw, 34px);
  font-weight: 900;
}

.case-compact p {
  max-width: 620px;
  margin-bottom: 0;
  color: var(--muted-text);
  line-height: 1.8;
}

.case-compact .btn {
  flex: 0 0 auto;
  padding: 13px 22px;
}

.case-grid {
  margin-top: 6px;
}

.case-grid[hidden] {
  display: none;
}

.case-card {
  overflow: hidden;
}

.case-compare {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 1px;
  background: var(--line);
}

.case-compare figure {
  position: relative;
  margin: 0;
  background: #eef6fb;
}

.case-compare img {
  display: block;
  width: 100%;
  aspect-ratio: 4 / 3;
  object-fit: cover;
}

.case-compare span {
  position: absolute;
  top: 10px;
  left: 10px;
  z-index: 1;
  padding: 5px 9px;
  color: #fff;
  background: rgba(12, 53, 86, 0.86);
  border-radius: 999px;
  font-size: 12px;
  font-weight: 900;
}

.case-content {
  padding: 22px;
}

.case-tag {
  display: inline-flex;
  margin-bottom: 14px;
  padding: 7px 12px;
  color: var(--brand-blue);
  background: var(--brand-blue-soft);
  border-radius: 999px;
  font-size: 13px;
  font-weight: 900;
}

.case-content dl {
  display: grid;
  gap: 10px;
  margin-bottom: 0;
}

.case-content dl div {
  display: grid;
  grid-template-columns: 82px 1fr;
  gap: 12px;
}

.case-content dt {
  color: var(--brand-blue-dark);
  font-weight: 900;
}

.case-content dd {
  margin-bottom: 0;
  color: var(--muted-text);
  line-height: 1.65;
}

.process-area {
  background: #fff;
}

.column-title {
  color: var(--brand-blue-dark);
  font-size: 28px;
  font-weight: 900;
  margin-bottom: 24px;
}

.process-steps {
  display: grid;
  gap: 14px;
}

.process-step {
  display: grid;
  grid-template-columns: 42px 1fr;
  gap: 16px;
  padding: 20px;
  background: var(--paper);
  border: 1px solid var(--line);
  border-radius: 18px;
  box-shadow: var(--shadow-card);
}

.process-step span {
  display: inline-grid;
  width: 42px;
  height: 42px;
  color: #fff;
  background: var(--brand-blue);
  border-radius: 50%;
  font-weight: 900;
  place-items: center;
}

.process-step h4 {
  margin-bottom: 6px;
  color: var(--brand-blue-dark);
  font-size: 18px;
  font-weight: 900;
}

.process-step p {
  margin-bottom: 0;
  color: var(--muted-text);
  line-height: 1.7;
}

.faq-box {
  display: grid;
  gap: 16px;
  padding: 24px;
  box-shadow: var(--shadow-card);
}

.faq-box article {
  padding: 20px;
  background: #f8fcff;
  border: 1px solid #e3eef5;
  border-radius: 16px;
}

.faq-box h4 {
  margin-bottom: 8px;
  font-size: 18px;
}

.faq-box p {
  margin-bottom: 0;
}

.contact-area {
  background: linear-gradient(180deg, #fffaf2, var(--brand-blue-soft));
}

.contact-info-box,
.contact-form {
  padding: 30px;
}

.contact-line-label {
  display: inline-flex;
  margin-bottom: 12px;
  padding: 7px 12px;
  color: var(--brand-blue);
  background: var(--brand-blue-soft);
  border-radius: 999px;
  font-size: 13px;
  font-weight: 900;
}

.contact-info-box h3 {
  font-size: 32px;
}

.contact-info-box ul {
  display: grid;
  gap: 14px;
  margin: 26px 0;
}

.contact-info-box li {
  display: flex;
  align-items: center;
  gap: 12px;
  color: var(--brand-blue-dark);
  font-size: 17px;
  font-weight: 900;
}

.contact-info-box i {
  display: inline-grid;
  width: 34px;
  height: 34px;
  color: var(--brand-blue);
  background: #fff;
  border: 1px solid var(--line);
  border-radius: 50%;
  place-items: center;
}

.contact-line-btn {
  width: 100%;
  padding: 13px 20px;
}

.contact-form label {
  color: var(--brand-blue-dark);
  font-weight: 800;
}

.form-control {
  min-height: 48px;
  border-color: var(--line);
  border-radius: 12px;
}

.form-note {
  min-height: 26px;
  margin: 14px 0 0;
  color: var(--brand-blue-dark);
  font-weight: 800;
}

.footer {
  background-color: #0b2439;
}

.footer-brand {
  display: flex;
  align-items: center;
  gap: 14px;
  margin-bottom: 20px;
}

.footer-brand img {
  width: 58px;
  height: 58px;
  object-fit: contain;
  background: #fff;
  border-radius: 50%;
}

.footer-brand h3 {
  color: #fff;
  margin-bottom: 2px;
}

.footer-brand p {
  margin-bottom: 0;
}

.footer-widget ul.list-arrow li {
  color: #999;
  border-bottom: 1px solid rgba(255, 255, 255, 0.08);
}

#back-to-top .btn.btn-primary {
  background: var(--brand-blue);
}

@media (min-width: 992px) {
  .hero-copy-col {
    flex: 0 0 55%;
    max-width: 55%;
  }

  .hero-media-col {
    flex: 0 0 45%;
    max-width: 45%;
  }
}

@media (max-width: 991px) {
  .header-right {
    display: none;
  }

  .hero-area {
    padding: 64px 0 50px;
  }

  .hero-copy h1 {
    font-size: 36px;
  }

  .trust-tags {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .conversion-visual {
    margin-right: auto;
  }
}

@media (max-width: 575px) {
  .top-bar-content {
    flex-direction: column;
    align-items: stretch;
    gap: 10px;
    padding: 10px 0;
  }

  .top-bar-main {
    display: grid;
    gap: 6px;
    font-size: 14px;
  }

  .top-bar-cta {
    width: 100%;
  }

  .logo-area {
    padding: 18px 0;
  }

  .hero-area {
    padding: 50px 0 44px;
  }

  .hero-copy h1 {
    font-size: 30px;
    line-height: 1.42;
  }

  .hero-copy p {
    font-size: 16px;
    line-height: 1.85;
  }

  .hero-actions {
    display: grid;
  }

  .hero-actions .btn,
  .cta-line-btn {
    width: 100%;
  }

  .trust-tags {
    grid-template-columns: 1fr;
    gap: 10px;
  }

  .conversion-visual {
    padding: 18px;
    border-radius: 22px;
  }

  .hero-image-wrap {
    padding: 10px;
    border-radius: 18px;
  }

  .hero-brand-image {
    max-width: 100%;
  }

  .hero-mini-tags {
    grid-template-columns: 1fr;
  }

  .call-to-action-box {
    margin-top: 0;
  }

  .call-to-action-box .action-style-box {
    padding: 24px 20px;
  }

  .section-padding {
    padding: 58px 0;
  }

  .section-sub-title {
    margin-bottom: 28px;
  }

  .service-card,
  .scene-card,
  .quote-card,
  .case-card,
  .faq-box,
  .contact-info-box,
  .contact-form {
    border-radius: 18px;
  }

  .service-card,
  .quote-card,
  .case-card,
  .contact-info-box,
  .contact-form {
    padding: 24px;
  }

  .case-compact {
    display: grid;
    padding: 24px;
    text-align: left;
  }

  .case-compact .btn {
    width: 100%;
  }

  .case-compare {
    grid-template-columns: 1fr;
  }

  .case-content dl div {
    grid-template-columns: 76px 1fr;
  }

  .process-step {
    grid-template-columns: 36px 1fr;
    padding: 18px;
  }

  .process-step span {
    width: 36px;
    height: 36px;
  }
}
